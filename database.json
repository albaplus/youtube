// vidstream-simulator.js
(function() {
  const STORAGE_KEY = 'vidstream_db_nbc';
  const TICK_INTERVAL_MS = 2000; // 2 segundos

  // Dados iniciais (caso não exista nada salvo)
  const INITIAL_DATA = { ... }; // cole o JSON acima aqui

  // --- Funções auxiliares ---
  function loadData() {
    const stored = localStorage.getItem(STORAGE_KEY);
    if (stored) {
      try {
        return JSON.parse(stored);
      } catch (e) {
        console.error('Erro ao parsear dados salvos, usando fallback.');
      }
    }
    // Se não houver dados salvos, clona o INITIAL_DATA
    return JSON.parse(JSON.stringify(INITIAL_DATA));
  }

  function saveData(data) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
  }

  // --- Lógica de incremento ---
  function applyTick(data) {
    // Atualiza apenas se o sistema de tick estiver ativo
    if (!data.system?.tick_system) return data;

    const fields = data.system.tick_system.update_fields || ['views', 'likes'];
    const boost = data.system.live_simulation?.active 
      ? data.system.live_simulation.boost_multiplier || 1.0 
      : 1.0;

    // Atualiza vídeos
    if (data.videos) {
      data.videos.forEach(video => {
        if (fields.includes('views')) {
          // Incremento base: ~30 views por tick (ajuste conforme desejar)
          const baseIncrement = Math.floor(25 + Math.random() * 15);
          video.views += Math.floor(baseIncrement * boost);
        }
        if (fields.includes('likes')) {
          const likeIncrement = Math.floor(video.views * (video.engagement?.like_ratio || 0.01) * 0.05);
          video.likes += Math.max(1, likeIncrement);
        }
        // Atualiza engagement velocity (apenas para referência)
        if (video.engagement) {
          video.engagement.velocity = (video.views / 10000).toFixed(1);
        }
      });
    }

    // Atualiza channel_stats
    if (data.channel_stats) {
      Object.keys(data.channel_stats).forEach(chId => {
        const stats = data.channel_stats[chId];
        const channelVideos = data.videos.filter(v => v.channel_id === chId);
        stats.total_views = channelVideos.reduce((sum, v) => sum + v.views, 0);
        stats.total_likes = channelVideos.reduce((sum, v) => sum + v.likes, 0);
        if (stats.analytics) {
          stats.analytics.views_last_7_days = stats.total_views;
          stats.analytics.watch_time_hours = Math.floor(stats.total_views * 0.008);
        }
        if (stats.monetization) {
          stats.monetization.total_earnings = parseFloat((stats.total_views * 0.0021).toFixed(2));
          stats.monetization.monthly_earnings = parseFloat((stats.monetization.total_earnings / 4).toFixed(2));
        }
      });
    }

    return data;
  }

  // --- Inicialização ---
  let appData = loadData();

  // Função de renderização (você deve adaptar ao seu HTML)
  function render() {
    const video = appData.videos[0];
    if (!video) return;

    // Exemplo: atualizar elementos com ids
    document.getElementById('views-count').textContent = video.views.toLocaleString();
    document.getElementById('likes-count').textContent = video.likes.toLocaleString();
    document.getElementById('subs-count').textContent = appData.channels[0].subscribers.toLocaleString();

    // Atualiza channel stats se necessário
    const stats = appData.channel_stats.ch_005;
    document.getElementById('total-channel-views').textContent = stats.total_views.toLocaleString();
  }

  // Tick loop
  function tick() {
    appData = applyTick(appData);
    if (appData.system.tick_system.persist) {
      saveData(appData);
    }
    render();
  }

  // Inicia o intervalo
  setInterval(tick, TICK_INTERVAL_MS);

  // Render inicial
  render();

  // Opcional: expor dados para debug
  window.vidstreamData = appData;
})();
